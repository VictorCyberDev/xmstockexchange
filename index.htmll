<script>
document.addEventListener('DOMContentLoaded', function () {
    const planSelect = document.getElementById('planSelect');
    const amountInput = document.getElementById('amountInput');
    const amountSlider = document.getElementById('amountSlider');
    const amountDisplay = document.getElementById('amountDisplay');
    const dailyProfitText = document.getElementById('dailyProfit');
    const totalProfitText = document.getElementById('totalProfit');

    function updateProfits() {
        const plan = planSelect.options[planSelect.selectedIndex];
        const rate = parseFloat(plan.getAttribute('data-rate'));
        const duration = parseInt(plan.getAttribute('data-duration'));
        const amount = parseFloat(amountInput.value) || 0;
        const dailyProfit = amount * rate;
        const totalProfit = dailyProfit * duration;
        dailyProfitText.textContent = '$' + dailyProfit.toFixed(2);
        totalProfitText.textContent = '$' + totalProfit.toFixed(2);
        amountDisplay.textContent = '$' + amount;
    }

    planSelect.addEventListener('change', function () {
        const plan = planSelect.options[planSelect.selectedIndex];
        const minAmount = parseInt(plan.getAttribute('data-min'));
        const maxAmount = parseInt(plan.getAttribute('data-max'));
        amountInput.min = minAmount;
        amountInput.max = maxAmount;
        amountSlider.min = minAmount;
        amountSlider.max = maxAmount;
        if (parseFloat(amountInput.value) < minAmount) amountInput.value = minAmount;
        amountSlider.value = amountInput.value;
        updateProfits();
    });

    amountInput.addEventListener('input', function () {
        amountSlider.value = amountInput.value;
        updateProfits();
    });

    amountSlider.addEventListener('input', function () {
        amountInput.value = amountSlider.value;
        updateProfits();
    });

    updateProfits();
});
</script>

