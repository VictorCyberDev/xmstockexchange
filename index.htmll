document.getElementById("depositBtn").addEventListener("click", function () {
    document.getElementById("deposit").style.display = "block";
    document.getElementById("withdraw").style.display = "none";
    document.getElementById("depositBtn").classList.add("transaction__tab__btn__active");
    document.getElementById("withdrawBtn").classList.remove("transaction__tab__btn__active");
});
document.getElementById("withdrawBtn").addEventListener("click", function () {
    document.getElementById("deposit").style.display = "none";
    document.getElementById("withdraw").style.display = "block";
    document.getElementById("withdrawBtn").classList.add("transaction__tab__btn__active");
    document.getElementById("depositBtn").classList.remove("transaction__tab__btn__active");
});
</script>

